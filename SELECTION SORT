arr=[2,5,9,1,3,8,6,4,0]
def selectionsort(arr):
    n=len(arr)
    for i in range(n):
        min_element=i 
        for j in range(i+1,n):
            if arr[j]<arr[min_element]:
                min_element=j
        arr[i],arr[min_element]=arr[min_element],arr[i]
    return arr
print(selectionsort(arr))      
